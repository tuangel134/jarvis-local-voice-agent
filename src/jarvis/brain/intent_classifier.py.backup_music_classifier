from __future__ import annotations

import re
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any

from jarvis.utils.text import normalize, remove_command_prefix


@dataclass
class Intent:
    name: str
    confidence: float = 1.0
    entities: dict[str, Any] = field(default_factory=dict)
    raw_text: str = ''


class IntentClassifier:
    def __init__(self, config: dict[str, Any]):
        self.config = config

    def classify(self, text: str) -> Intent:
        raw = (text or '').strip()
        t = normalize(raw)
        security = self.config.get('security', {}) or {}
        url_aliases = security.get('url_aliases', {}) or {}
        app_aliases = security.get('app_aliases', {}) or {}
        service_aliases = security.get('service_aliases', {}) or {}

        if not t:
            return Intent('unknown', 0.0, raw_text=raw)

        if any(x in t for x in ['deja de escuchar', 'apagate', 'desactivate', 'duermete', 'apágate', 'desactívate', 'duérmete']):
            return Intent('stop_listening', raw_text=raw)

        if any(x in t for x in ['usa la ia avanzada', 'modelo potente', 'esto es pesado', 'analiza este error', 'revisa este log', 'programa', 'genera codigo', 'genera código']):
            return Intent('heavy_reasoning', raw_text=raw)

        if any(x in t for x in ['que hora es', 'qué hora es', 'dime la hora', 'hora actual', 'hora es']):
            return Intent('get_time', raw_text=raw)

        if any(x in t for x in ['que fecha es', 'qué fecha es', 'fecha de hoy', 'dia es hoy', 'día es hoy']):
            return Intent('get_date', raw_text=raw)

        if any(x in t for x in ['estado del sistema', 'como esta la pc', 'cómo está la pc', 'memoria', 'cpu', 'disco']):
            return Intent('system_status', raw_text=raw)

        # Servicios configurables.
        service = self._extract_service(t, service_aliases)
        if service and any(x in t for x in ['revisa', 'estado', 'activo', 'corriendo', 'esta arriba', 'está arriba', 'servicio', 'como esta', 'cómo está']):
            return Intent('service_status', entities={'service': service}, raw_text=raw)

        # Abrir URL directa escrita.
        direct_url = re.search(r'https?://\S+', raw)
        if direct_url:
            return Intent('open_url', entities={'url': direct_url.group(0), 'target': direct_url.group(0)}, raw_text=raw)

        # Crear notas / recordatorios / archivos.
        if any(x in t for x in ['crea una nota', 'crear una nota', 'guarda una nota', 'nota que diga']):
            content = re.sub(r'.*?(crea una nota|crear una nota|guarda una nota|nota que diga)\s*(que diga)?', '', raw, flags=re.I).strip(' :')
            return Intent('create_note', entities={'content': content or raw}, raw_text=raw)

        if any(x in t for x in ['lee notas', 'leer notas', 'ultimas notas', 'últimas notas']):
            return Intent('read_note', raw_text=raw)

        if any(x in t for x in ['busca el archivo', 'buscar archivo', 'encuentra el archivo', 'busca archivo']):
            query = re.sub(r'.*?(busca|buscar|encuentra)\s+(el\s+)?archivo\s+', '', raw, flags=re.I).strip()
            return Intent('search_file', entities={'query': query}, raw_text=raw)

        if any(x in t for x in ['recordatorio', 'recuerdame', 'recuérdame']):
            return Intent('create_reminder', entities={'text': raw}, raw_text=raw)

        if any(x in t for x in ['lista recordatorios', 'mis recordatorios']):
            return Intent('list_reminders', raw_text=raw)

        if any(x in t for x in ['ejecuta', 'corre comando', 'ejecuta comando']):
            command = remove_command_prefix(raw)
            return Intent('safe_shell', entities={'command': command}, raw_text=raw)

        # Abrir/poner/iniciar/lanzar. Esto cubre "abre calculadora", "pon vlc", "lanza discord".
        target = self._extract_open_target(t)
        if target:
            url = self._url_from_target(target, url_aliases)
            if url:
                return Intent('open_url', entities={'url': url, 'target': target}, raw_text=raw)

            folder = self._folder_from_target(target)
            if folder:
                return Intent('open_folder', entities={'path': str(folder), 'target': target}, raw_text=raw)

            # Si coincide con alias de app o simplemente es algo que se quiere abrir, mandarlo a AppsSkill.
            return Intent('open_app', entities={'app': target}, raw_text=raw)

        # Si el usuario dice solo "youtube" o "calculadora" después de wake word.
        url = self._url_from_target(t, url_aliases)
        if url:
            return Intent('open_url', entities={'url': url, 'target': t}, raw_text=raw)

        if self._looks_like_app(t, app_aliases):
            return Intent('open_app', entities={'app': t}, raw_text=raw)

        return Intent('chat', 0.6, raw_text=raw)

    def _extract_open_target(self, t: str) -> str | None:
        prefixes = [
            'abre', 'abrir', 'abreme', 'ábreme', 'lanza', 'inicia', 'ejecuta', 'arranca',
            'abre la', 'abre el', 'abre los', 'abre las', 'pon', 'ponme', 'muestra', 'muestrame', 'muéstrame',
            'quiero abrir', 'necesito abrir', 've a', 'ir a', 'navega a', 'entra a',
        ]
        for prefix in sorted(prefixes, key=len, reverse=True):
            if t == prefix:
                return None
            if t.startswith(prefix + ' '):
                target = t[len(prefix):].strip()
                target = re.sub(r'^(la|el|los|las|un|una)\s+', '', target).strip()
                return target or None
        return None

    def _url_from_target(self, target: str, aliases: dict[str, str]) -> str | None:
        target_n = normalize(target)
        for key, url in aliases.items():
            if normalize(str(key)) in target_n:
                return str(url)
        if target.startswith(('http://', 'https://')):
            return target
        if re.match(r'^[\w.-]+\.[a-z]{2,}(/.*)?$', target):
            return 'https://' + target
        return None

    def _folder_from_target(self, target: str) -> Path | None:
        mapping = {
            'descargas': '~/Descargas', 'downloads': '~/Downloads',
            'documentos': '~/Documentos', 'documents': '~/Documents',
            'escritorio': '~/Escritorio', 'desktop': '~/Desktop',
            'videos': '~/Videos', 'vídeos': '~/Videos',
            'imagenes': '~/Imágenes', 'imágenes': '~/Imágenes',
            'musica': '~/Música', 'música': '~/Música',
            'home': '~', 'inicio': '~', 'carpeta personal': '~',
            'notas': '~/NotasJarvis', 'notas jarvis': '~/NotasJarvis',
        }
        target_n = normalize(target)
        for key, folder in mapping.items():
            if normalize(key) in target_n:
                return Path(folder).expanduser()
        if target.startswith('~/') or target.startswith('/'):
            return Path(target).expanduser()
        return None

    def _extract_service(self, text: str, service_aliases: dict[str, str]) -> str | None:
        for alias, service in service_aliases.items():
            if normalize(str(alias)) in text:
                return str(service)
        for svc in ('jellyfin', 'immich', 'docker', 'ssh', 'ollama', 'tailscale', 'nginx', 'apache'):
            if svc in text:
                return svc
        return None

    def _looks_like_app(self, text: str, app_aliases: dict[str, Any]) -> bool:
        for alias in app_aliases.keys():
            if normalize(str(alias)) == text:
                return True
        return False
